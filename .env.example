# Credenciais do app Spotify (Client Credentials Flow - NÃO precisa de conta Premium para isso,
# é só pra busca de músicas). Crie um app gratuito em https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# String de conexão do banco Postgres. Quando você criar o "Vercel Postgres" no
# dashboard do seu projeto (aba Storage), o Vercel já injeta isso automaticamente
# em produção. Pra rodar/testar na sua máquina, copie o valor de POSTGRES_URL
# que aparece lá no dashboard (Storage > seu banco > .env.local) e cole aqui.
POSTGRES_URL=

# Porta onde o servidor vai rodar localmente
PORT=3000

# URL pública usada para gerar o QR code que o aluno escaneia.
# Localmente: http://localhost:3000
# Depois do deploy: a URL que o Vercel te der, ex: https://som-da-academia.vercel.app
PUBLIC_URL=http://localhost:3000
